{
  "name": "@render-engine/capture-worker",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -p src/tsconfig.json",
    "build:local": "tsc -p local/tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx local/index.ts",
    "test": "node --test dist/**/*.test.js",
    "test:local": "npx tsx --test tests/locals/*.test.ts",
    "lint": "eslint . --ext .ts",
    "seed:local": "tsx scripts/local/seed-jobs.ts",
    "clean": "rm -rf dist dist-local output local-queue.json src/*.tsbuildinfo local/*.tsbuildinfo"
  },
  "dependencies": {
    "@render-engine/shared-types": "*",
    "playwright": "^1.40.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
