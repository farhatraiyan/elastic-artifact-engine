{
  "name": "@capture-automation-platform/browser-orchestrator",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "build:core": "tsc -p tsconfig.core.json",
    "clean": "rm -rf dist* **/*.tsbuildinfo **/*.d.ts.map **/*.js.map",
    "dev": "tsx src/index.ts",
    "ingress": "tsx scripts/dev-cli.ts",
    "lint": "eslint .",
    "start": "node dist/index.js",
    "test": "npx nf start --procfile Procfile.test"
  },
  "dependencies": {
    "@mozilla/readability": "^0.6.0",
    "@capture-automation-platform/shared-types": "*",
    "@capture-automation-platform/azure-adapters": "*",
    "playwright-core": "^1.58.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.0.0",
    "zod": "^4.3.6"
  }
}