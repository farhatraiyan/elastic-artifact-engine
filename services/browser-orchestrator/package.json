{
  "name": "@render-engine/browser-orchestrator",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "build:core": "tsc -p tsconfig.core.json",
    "clean": "rm -rf dist* **/*.tsbuildinfo **/*.d.ts.map **/*.js.map",
    "dev": "tsx src/index.ts",
    "ingress": "tsx scripts/dev-cli.ts",
    "lint": "eslint .",
    "posttest": "rm -rf dist-core",
    "services:up": "docker compose -f docker/dev/docker-compose.yml up -d",
    "services:down": "docker compose -f docker/dev/docker-compose.yml down",
    "start": "node dist/index.js",
    "test": "npm run services:up && (npm run build:core && node --test dist-core/tests/*.test.js) && npm run services:down"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.31.0",
    "@azure/storage-queue": "^12.29.0",
    "@mozilla/readability": "^0.6.0",
    "@render-engine/shared-types": "*",
    "playwright-core": "^1.58.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.0.0",
    "zod": "^4.3.6"
  }
}