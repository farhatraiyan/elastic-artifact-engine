{
  "name": "@capture-automation-platform/browser-orchestrator",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist* **/*.tsbuildinfo **/*.d.ts.map **/*.js.map",
    "dev": "tsx src/index.ts",
    "ingress": "tsx scripts/dev-cli.ts",
    "lint": "eslint .",
    "start": "pm2 start ../../platform.config.cjs --only browser-orchestrator",
    "test": "node --import tsx --test --test-timeout=60000 tests/*.test.ts"
  },
  "dependencies": {
    "@azure/identity": "^4.0.0",
    "@capture-automation-platform/azure-adapters": "*",
    "@capture-automation-platform/shared-types": "*",
    "@mozilla/readability": "^0.6.0",
    "playwright-core": "^1.58.2",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@types/turndown": "^5.0.6"
  }
}
