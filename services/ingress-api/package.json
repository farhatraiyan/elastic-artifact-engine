{
  "name": "@capture-automation-platform/ingress-api",
  "version": "1.0.0",
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist* **/*.tsbuildinfo **/*.d.ts.map **/*.js.map",
    "lint": "eslint src tests",
    "start": "wait-on tcp:10000 tcp:10001 tcp:10002 && pm2 start ../../platform.config.cjs --only ingress-api && wait-on tcp:7071",
    "test": "node --import tsx --test --test-timeout=60000 tests/*.test.ts"
  },
  "dependencies": {
    "@azure/functions": "^4.6.0",
    "@capture-automation-platform/shared-types": "*",
    "@capture-automation-platform/azure-adapters": "*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "azure-functions-core-tools": "^4.0.6610",
    "typescript": "^6.0.2"
  }
}