{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "types": ["node"],
    "paths": {
      "@elastic-artifact-engine/shared-types": ["./packages/shared-types/src/index.ts"],
      "@elastic-artifact-engine/azure-adapters": ["./packages/azure-adapters/src/index.ts"],
      "@elastic-artifact-engine/browser-orchestrator": ["./services/browser-orchestrator/src/index.ts"]
    }
  }
}
